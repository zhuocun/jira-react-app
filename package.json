{
    "name": "jira-react-app",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "start": "vite --host 0.0.0.0 --port 3000",
        "build": "vite build",
        "test": "jest",
        "prepare": "husky install",
        "prettier": "prettier -c .prettierrc --write .",
        "eslint": "eslint src __json_server_mock__ eslint.config.mjs vite.config.ts jest.config.cjs babel.config.cjs commitlint.config.js --fix",
        "pre-commit": "npm run prettier && npm run eslint",
        "server": "json-server __json_server_mock__/db.json --port 8080"
    },
    "dependencies": {
        "@ant-design/icons": "^6.1.1",
        "@commitlint/cli": "^20.5.2",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@hello-pangea/dnd": "^18.0.1",
        "@reduxjs/toolkit": "^2.11.2",
        "@tanstack/react-query": "^5.100.5",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.24",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "antd": "^6.3.6",
        "dayjs": "^1.11.20",
        "lodash": "^4.18.1",
        "mobx": "^6.15.0",
        "mobx-react": "^9.2.1",
        "postcss": "^8.5.10",
        "qs": "^6.15.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-redux": "^9.2.0",
        "react-router": "^7.14.2",
        "react-router-dom": "^7.14.2",
        "web-vitals": "^5.2.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@testing-library/dom": "^10.4.1",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-jest": "^30.3.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "json-server": "^1.0.0-beta.15",
        "lint-staged": "^16.4.0",
        "msw": "^2.13.6",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-svgr": "^5.2.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "lint-staged": {
        "*.{js,css,md,ts,tsx}": "prettier --write"
    }
}
